# solostereo environment variables
# Copy to .env.local and fill in as needed.

# Path to the SQLite database file (defaults to data/solostereo.db if unset)
# SOLOSTEREO_DB_PATH=data/solostereo.db

# Spotify OAuth (Phase 7 — live "recently played" sync; optional, not needed
# for the historical import). Create an app at
# https://developer.spotify.com/dashboard and add the EXACT redirect URI below
# to the app's settings. Spotify requires a loopback IP (127.0.0.1), not
# "localhost", for http redirect URIs — so open the app at http://127.0.0.1:3000
# when connecting.
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback
